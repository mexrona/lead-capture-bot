# Telegram
BOT_TOKEN=your_bot_token_here
MANAGER_CHAT_ID=123456789

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_WORKSHEET_NAME=Leads

# Storage backend for leads: google_sheets (default)
LEAD_STORAGE_BACKEND=google_sheets

# FSM storage: memory | sqlite | postgresql
FSM_STORAGE=sqlite
FSM_SQLITE_PATH=data/fsm.db

# PostgreSQL (production FSM + optional future lead storage)
POSTGRES_DSN=postgresql+asyncpg://leadbot:leadbot@postgres:5432/leadbot

# Bot behaviour
DRAFT_TIMEOUT_HOURS=24
REMINDER_MINUTES=15
LOG_LEVEL=INFO

# AI / NLP (disabled by default)
NLP_ENABLED=false

# Manager contacts shown to user after submission
MANAGER_CONTACT_NAME=Менеджер
MANAGER_CONTACT_PHONE=+7 (999) 000-00-00
MANAGER_CONTACT_TELEGRAM=@manager
